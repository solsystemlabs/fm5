# Production Environment Variables
# Copy this file to .env.production and update with your production values

# Database Configuration
DATABASE_URL="postgresql://prod_user:secure_password@your-db-host:5432/fm5_production"
DIRECT_URL="postgresql://prod_user:secure_password@your-db-host:5432/fm5_production"

# Authentication
BETTER_AUTH_SECRET="your-production-secret-minimum-32-characters-long"
BETTER_AUTH_URL="https://yourapp.com"

# Application Configuration
NODE_ENV="production"
PORT=3000

# Security Headers
FORCE_HTTPS=true
TRUSTED_HOSTS="yourapp.com,www.yourapp.com"

# File Upload Configuration
UPLOAD_MAX_SIZE=10485760  # 10MB in bytes
ALLOWED_FILE_TYPES="image/jpeg,image/png,image/webp"

# Email Configuration
SMTP_HOST="smtp.mailgun.org"
SMTP_PORT=587
SMTP_USER="postmaster@mg.yourapp.com"
SMTP_PASS="your-mailgun-password"
SMTP_FROM="noreply@yourapp.com"

# Monitoring and Analytics
SENTRY_DSN="https://your-production-sentry-dsn@sentry.io/project-id"
GOOGLE_ANALYTICS_ID="GA-XXXXXXXXX"

# Rate Limiting (stricter in production)
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=50

# CORS Configuration
CORS_ORIGINS="https://yourapp.com,https://www.yourapp.com"

# Redis (for sessions and caching)
REDIS_URL="redis://your-redis-host:6379"

# S3 Compatible Storage
S3_ENDPOINT="https://s3.amazonaws.com"
S3_BUCKET="yourapp-production-uploads"
S3_ACCESS_KEY_ID="your-production-access-key"
S3_SECRET_ACCESS_KEY="your-production-secret-key"
S3_REGION="us-east-1"

# CDN Configuration
CDN_URL="https://cdn.yourapp.com"

# Health Check Configuration
HEALTH_CHECK_TOKEN="your-secure-health-check-token"

# Logging
LOG_LEVEL="info"
LOG_FORMAT="json"

# Database Connection Pool
DATABASE_CONNECTION_LIMIT=20
DATABASE_POOL_TIMEOUT=60000