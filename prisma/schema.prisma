generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model ModelCategory {
  id    Int     @id @unique @default(autoincrement())
  name  String  @unique
  Model Model[]
}

model Model {
  id              Int           @id @unique @default(autoincrement())
  name            String        @unique
  modelCategoryId Int
  Category        ModelCategory @relation(fields: [modelCategoryId], references: [id])
  Filaments       Filament[]    @relation("FilamentToModel")
}

model Filament {
  id             Int          @id @unique @default(autoincrement())
  name           String
  color          String
  materialTypeId Int
  Material       MaterialType @relation(fields: [materialTypeId], references: [id])
  Models         Model[]      @relation("FilamentToModel")
  cost           Float?
  grams          Int?
  Brand          Brand        @relation(fields: [brandName], references: [name])
  brandName      String
  diameter       Float
}

model Brand {
  id       Int        @id @unique @default(autoincrement())
  name     String     @unique
  Filament Filament[]
}

model MaterialType {
  id       Int        @id @unique @default(autoincrement())
  name     String     @unique
  Filament Filament[]
}
