generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model ModelCategory {
  id    Int     @id @unique @default(autoincrement())
  name  String  @unique
  Model Model[]
}

model Model {
  id              Int           @id @unique @default(autoincrement())
  name            String        @unique
  modelCategoryId Int
  Category        ModelCategory @relation(fields: [modelCategoryId], references: [id])
  Filaments       Filament[]    @relation("FilamentToModel")
  ModelFiles      ModelFile[]
  Product         Product[]
}

model ModelFile {
  id          Int          @id @unique @default(autoincrement())
  name        String       @unique
  modelId     Int
  url         String
  size        Int
  Filaments   Filament[]
  Model       Model        @relation(fields: [modelId], references: [id])
  SlicedFiles SlicedFile[]
}

model SlicedFile {
  id          Int        @id @unique @default(autoincrement())
  name        String     @unique
  modelId     Int
  url         String
  size        Int
  ModelFile   ModelFile? @relation(fields: [modelFileId], references: [id])
  modelFileId Int?
  Product     Product[]
}

model Filament {
  id             Int          @id @unique @default(autoincrement())
  name           String
  color          String
  filamentTypeId Int
  Type           FilamentType @relation(fields: [filamentTypeId], references: [id])
  materialTypeId Int
  Material       MaterialType @relation(fields: [materialTypeId], references: [id])
  Models         Model[]      @relation("FilamentToModel")
  cost           Float?
  grams          Int?
  Brand          Brand        @relation(fields: [brandName], references: [name])
  brandName      String
  diameter       Float
  ModelFile      ModelFile?   @relation(fields: [modelFileId], references: [id])
  modelFileId    Int?
  Product        Product?     @relation(fields: [productId], references: [id])
  productId      Int?
}

model Product {
  id           Int        @id @unique @default(autoincrement())
  name         String
  Filaments    Filament[]
  model        Model      @relation(fields: [modelId], references: [id])
  modelId      Int
  price        Float?
  slicedFile   SlicedFile @relation(fields: [slicedFileId], references: [id])
  slicedFileId Int
}

model FilamentType {
  id          Int        @id @unique @default(autoincrement())
  name        String
  description String?
  Filament    Filament[]
}

model Brand {
  id       Int        @id @unique @default(autoincrement())
  name     String     @unique
  Filament Filament[]
}

model MaterialType {
  id       Int        @id @unique @default(autoincrement())
  name     String     @unique
  Filament Filament[]
}
