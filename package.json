{
  "type": "module",
  "scripts": {
    "dev": "npm run db:start && npm run db:migrate && vite dev",
    "dev:clean": "npm run db:reset && npm run dev",
    "build": "vite build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:all": "npm run test:run && npm run test:e2e",
    "db:start": "docker compose up -d postgres && npm run db:wait",
    "db:stop": "docker compose down",
    "db:restart": "npm run db:stop && npm run db:start",
    "db:wait": "node scripts/wait-for-db.js",
    "db:migrate": "prisma migrate dev --skip-generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "npm run db:stop && docker compose down -v && npm run db:start && npm run db:migrate && npm run db:seed",
    "db:studio": "prisma studio",
    "docker:logs": "docker compose logs -f postgres",
    "env:local": "node scripts/setup-env.js local",
    "env:staging": "node scripts/setup-env.js staging",
    "env:production": "node scripts/setup-env.js production"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.876.0",
    "@aws-sdk/s3-request-presigner": "^3.876.0",
    "@heroicons/react": "^2.2.0",
    "@prisma/client": "^6.13.0",
    "@tailwindcss/postcss": "^4.1.11",
    "@tailwindcss/vite": "^4.1.11",
    "@tanstack/react-form": "^1.15.2",
    "@tanstack/react-query": "^5.84.1",
    "@tanstack/react-router": "^1.130.12",
    "@tanstack/react-start": "^1.130.15",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/zod-form-adapter": "^0.42.1",
    "@trpc/client": "^11.5.0",
    "@trpc/server": "^11.5.0",
    "@trpc/tanstack-react-query": "^11.5.0",
    "bcryptjs": "^2.4.3",
    "better-auth": "^1.3.4",
    "clsx": "^2.1.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.541.0",
    "playwright": "^1.54.2",
    "postcss": "^8.5.6",
    "react": "^19.1.1",
    "react-aria-components": "^1.11.0",
    "react-dom": "^19.1.1",
    "tailwind-merge": "^3.3.1",
    "tailwind-variants": "^2.1.0",
    "tailwindcss-animate": "^1.0.7",
    "tailwindcss-react-aria-components": "^2.0.0",
    "tw-animate-css": "^1.3.6",
    "vite": "^7.0.6",
    "vite-tsconfig-paths": "^5.1.4",
    "xml2js": "^0.6.2",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@testing-library/jest-dom": "^6.7.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/jszip": "^3.4.0",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@types/xml2js": "^0.4.14",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^3.2.4",
    "happy-dom": "^18.0.1",
    "jsdom": "^26.1.0",
    "msw": "^2.10.5",
    "pg": "^8.16.3",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "prisma": "^6.13.0",
    "tailwindcss": "^4.1.11",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
