generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model ModelCategory {
  id    Int     @id @default(autoincrement())
  name  String  @unique
  Model Model[]
}

model Model {
  id              Int           @id @default(autoincrement())
  name            String        @unique
  modelCategoryId Int
  Category        ModelCategory @relation(fields: [modelCategoryId], references: [id])
  Filaments       Filament[]    @relation("FilamentToModel")
  ModelFiles      ModelFile[]
  ThreeMFFiles    ThreeMFFile[] // New relationship for 3MF containers
  Products        Product[]
}

model ModelFile {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  modelId   Int
  url       String
  size      Int
  s3Key     String?
  fileType  String     // "stl", "obj", etc. (non-3MF files)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  Filaments Filament[]
  Model     Model      @relation(fields: [modelId], references: [id])
}

// New ThreeMFFile entity for 3MF containers
model ThreeMFFile {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  url       String
  size      Int
  s3Key     String?
  modelId   Int      // Required parent
  hasGcode  Boolean  @default(false) // .gcode.3mf vs .3mf
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  Model       Model        @relation(fields: [modelId], references: [id])
  SlicedFiles SlicedFile[] // Children sliced files
}

// Tagged union file system - replaces ModelImage
model File {
  id         Int            @id @default(autoincrement())
  name       String
  url        String
  size       Int
  s3Key      String?
  mimeType   String?
  entityType FileEntityType
  entityId   Int            // References Model.id, ThreeMFFile.id, or SlicedFile.id
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@unique([entityType, entityId, name]) // Prevent duplicate filenames per entity
}

enum FileEntityType {
  MODEL        // Standalone files uploaded to model
  THREE_MF     // Images extracted from 3MF file
  SLICED_FILE  // Images extracted from sliced file
}

model SlicedFile {
  id            Int     @id @default(autoincrement())
  name          String  @unique
  threeMFFileId Int     // Required parent - no orphaned SlicedFiles
  url           String
  size          Int
  s3Key         String? // S3 object key for file management

  // Basic print information
  printTimeMinutes Int? // from "model printing time"
  totalTimeMinutes Int? // from "total estimated time"  
  layerCount       Int? // from "total layer number"
  layerHeight      Float? // from layer_height config
  maxZHeight       Float? // from "max_z_height"

  // Slicer information
  slicerName    String? // e.g., "BambuStudio"
  slicerVersion String? // e.g., "02.01.01.52"
  profileName   String? // from filament_settings_id

  // Printer settings
  nozzleDiameter Float? // from nozzle_diameter
  bedType        String? // from bed_type
  bedTemperature Int? // from hot_plate_temp

  // Filament totals (aggregated across all filaments)
  totalFilamentLength Float? // total length in mm
  totalFilamentVolume Float? // total volume in cm³ 
  totalFilamentWeight Float? // total weight in grams

  // File metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  ThreeMFFile         ThreeMFFile        @relation(fields: [threeMFFileId], references: [id])
  Products            Product[]
  SlicedFileFilaments SlicedFileFilament[] // Junction table for multi-filament
}

// Junction table for multi-filament support
model SlicedFileFilament {
  id            Int @id @default(autoincrement())
  slicedFileId  Int
  filamentIndex Int // 0, 1, 2, etc. for multi-filament prints

  // Per-filament total usage
  lengthUsed Float? // total length in mm for this specific filament
  volumeUsed Float? // total volume in cm³ for this specific filament  
  weightUsed Float? // total weight in grams for this specific filament

  // Usage breakdown by purpose (when available from slicer)
  modelLength Float? // length used for actual model parts
  modelVolume Float? // volume used for actual model parts
  modelWeight Float? // weight used for actual model parts

  supportLength Float? // length used for support structures
  supportVolume Float? // volume used for support structures
  supportWeight Float? // weight used for support structures

  towerLength Float? // length used for purge/prime tower
  towerVolume Float? // volume used for purge/prime tower
  towerWeight Float? // weight used for purge/prime tower

  wasteLength Float? // length used for waste/purge operations
  wasteVolume Float? // volume used for waste/purge operations
  wasteWeight Float? // weight used for waste/purge operations

  infillLength Float? // length used for infill (subset of model)
  infillVolume Float? // volume used for infill (subset of model)
  infillWeight Float? // weight used for infill (subset of model)

  wallLength Float? // length used for walls/perimeters (subset of model)
  wallVolume Float? // volume used for walls/perimeters (subset of model)
  wallWeight Float? // weight used for walls/perimeters (subset of model)

  // Filament properties at slice time
  filamentType   String? // PLA, ABS, PETG, etc.
  filamentColor  String? // hex color code
  filamentVendor String? // brand name
  density        Float? // density value
  diameter       Float? // filament diameter

  // Temperature settings
  nozzleTemp Int? // nozzle temperature for this filament
  bedTemp    Int? // bed temperature for this filament

  // Optional relationship to existing Filament record
  filamentId Int? // Link to existing Filament if identified
  filament   Filament? @relation(fields: [filamentId], references: [id])

  slicedFile SlicedFile @relation(fields: [slicedFileId], references: [id])

  @@unique([slicedFileId, filamentIndex])
}

model Filament {
  id                  Int                  @id @default(autoincrement())
  name                String
  color               String
  filamentTypeId      Int
  Type                FilamentType         @relation(fields: [filamentTypeId], references: [id])
  materialTypeId      Int
  Material            MaterialType         @relation(fields: [materialTypeId], references: [id])
  Models              Model[]              @relation("FilamentToModel")
  cost                Float?
  grams               Int?
  Brand               Brand                @relation(fields: [brandName], references: [name])
  brandName           String
  diameter            Float
  ModelFile           ModelFile?           @relation(fields: [modelFileId], references: [id])
  modelFileId         Int?
  Product             Product?             @relation(fields: [productId], references: [id])
  productId           Int?
  SlicedFileFilaments SlicedFileFilament[] // Relationship to junction table
}

model Product {
  id           Int        @id @default(autoincrement())
  name         String
  Filaments    Filament[]
  model        Model      @relation(fields: [modelId], references: [id])
  modelId      Int
  price        Float?
  slicedFile   SlicedFile @relation(fields: [slicedFileId], references: [id])
  slicedFileId Int
}

model FilamentType {
  id          Int        @id @default(autoincrement())
  name        String
  description String?
  Filament    Filament[]
}

model Brand {
  id       Int        @id @default(autoincrement())
  name     String     @unique
  Filament Filament[]
}

model MaterialType {
  id       Int        @id @default(autoincrement())
  name     String     @unique
  Filament Filament[]
}

// Dashboard Analytics Models
model DashboardAnalytics {
  id                    Int      @id @default(autoincrement())
  date                  DateTime @default(now()) @db.Date
  totalFilaments        Int      @default(0)
  totalModels           Int      @default(0)
  totalProducts         Int      @default(0)
  totalSlicedFiles      Int      @default(0)
  totalPrintTimeMinutes Int?     // Aggregate print time
  totalFilamentWeight   Float?   // Aggregate filament weight used
  totalFilamentCost     Float?   // Aggregate estimated cost
  mostUsedMaterialType  String?
  mostUsedBrand         String?
  avgPrintTime          Float?   // Average print time in minutes
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([date])
}

model RecentActivity {
  id          Int          @id @default(autoincrement())
  type        ActivityType
  title       String
  description String?
  entityType  String // "filament", "model", "product", "sliced_file"
  entityId    Int
  metadata    Json? // Flexible field for additional data
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

enum ActivityType {
  CREATED
  UPDATED
  DELETED
  UPLOADED
  DOWNLOADED
}
